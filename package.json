{
  "name": "@spikalabs/design-kit",
  "version": "0.2.0",
  "description": "Project-scoped spikalabs design-kit skills installer for Codex and Claude Code.",
  "license": "MIT",
  "author": {
    "name": "Chan Kang",
    "email": "chan.kang@spikalabs.co.kr"
  },
  "homepage": "https://github.com/spikalabscorp/spikalabs-design-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spikalabscorp/spikalabs-design-kit.git"
  },
  "bugs": {
    "url": "https://github.com/spikalabscorp/spikalabs-design-kit/issues"
  },
  "type": "module",
  "bin": {
    "spikalabs-design-kit": "./bin/spikalabs-design-kit.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    "docs/",
    "assets/brand/",
    ".agents/skills/",
    ".agents/plugins/",
    ".claude/skills/",
    ".claude-plugin/",
    ".codex-plugin/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE.md",
    "skill.sh"
  ],
  "keywords": [
    "agent-skills",
    "codex",
    "claude-code",
    "spikalabs",
    "design-system",
    "neo-brutalism"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "install:project-scope": "node ./bin/spikalabs-design-kit.mjs install-project-scope",
    "list-skills": "node ./bin/spikalabs-design-kit.mjs list",
    "agent-prompt": "node ./bin/spikalabs-design-kit.mjs agent-prompt",
    "pack:dry-run": "npm pack --dry-run"
  }
}
